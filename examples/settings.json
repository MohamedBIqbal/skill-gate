{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/skill-first-check.sh",
            "timeout": 5,
            "statusMessage": "Checking project skills..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-compact-remind.sh",
            "timeout": 5,
            "statusMessage": "Re-injecting skill awareness..."
          }
        ]
      }
    ]
  }
}
